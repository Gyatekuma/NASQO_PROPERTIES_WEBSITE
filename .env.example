# Public site URL (no trailing slash). Required for correct canonicals, OG URLs, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=http://nasqoproperties.com

# Google Analytics 4 — Measurement ID (e.g. G-XXXXXXXXXX). Optional; omit to disable GA script.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console HTML tag verification content value only (optional).
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: Twitter/X handle for twitter:site / twitter:creator (e.g. @YourBrand)
NEXT_PUBLIC_TWITTER_SITE=
